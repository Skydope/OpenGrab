# ytgrab — environment configuration
# Copy this file to .env and adjust values as needed.

# Bind address (use 0.0.0.0 for Docker, 127.0.0.1 for local-only)
YTGRAB_HOST=0.0.0.0

# HTTP server port
YTGRAB_PORT=8800

# Output directory for downloaded files
YTGRAB_DIR=/downloads

# Optional: set a token to protect the web UI and API.
# Leave empty for open access (only recommended on trusted LANs).
YTGRAB_TOKEN=

# Maximum concurrent downloads (default: 2)
YTGRAB_MAX_JOBS=2

# Reject formats larger than this size in MB (0 = unlimited)
YTGRAB_MAX_SIZE_MB=0

# Auto-update yt-dlp on container start (1 = yes, 0 = no)
# YouTube changes its player often; keeping this on avoids breakage.
YTGRAB_AUTOUPDATE=1
