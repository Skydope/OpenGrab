# OpenGrab — Environment configuration
# Copy this file to .env and adjust as needed.
#
# Auth: if OPENGRAB_TOKEN is left empty (or unset), a random token is
# generated at startup and printed to the logs. To run with NO auth at all
# (local dev only), set OPENGRAB_NO_AUTH=1 explicitly.
#
# If you want to expose OpenGrab on your LAN or internet:
#   - Set OPENGRAB_HOST=0.0.0.0
#   - Set OPENGRAB_TOKEN to a strong random value (or use the auto-generated one)
#   - Or place OpenGrab behind an nginx reverse proxy with TLS

OPENGRAB_HOST=127.0.0.1
OPENGRAB_PORT=8800
OPENGRAB_DIR=./downloads
OPENGRAB_TOKEN=
# OPENGRAB_NO_AUTH=0
OPENGRAB_MAX_JOBS=2
OPENGRAB_MAX_SIZE_MB=0
# Budget total de disco en MB para OPENGRAB_DIR. 0 = sin limite.
# Si el uso actual lo supera, se rechazan nuevos jobs (507) hasta que borres.
OPENGRAB_MAX_TOTAL_MB=0
# Auto-update de yt-dlp al arrancar. 0 = off (recomendado; supply-chain).
# yt-dlp viene pineado en requirements.txt; Dependabot lo mantiene fresco.
OPENGRAB_AUTOUPDATE=0
# Si activas AUTOUPDATE, fija una version exacta aca (vacio = ultima).
OPENGRAB_YTDLP_VERSION=
# Confia en X-Forwarded-For para rate limiting (1 = si, detras de nginx).
# ATENCION: si OpenGrab recibe trafico directo, deja esto en 0 (spoofing).
OPENGRAB_TRUST_XFF=0
# Ruta al archivo config.ini donde la UI persiste settings (tema, calidad, etc.).
# Desktop mode: default %APPDATA%\OpenGrab\config.ini (Windows) o
#   $XDG_CONFIG_HOME/OpenGrab/config.ini (Linux).
# Docker: setealo a /downloads/config.ini para que los settings persistan
#   en el volumen junto con la DB (el compose ya lo hace por default).
# OPENGRAB_CONFIG=
# Activa sobreescritura segura de 3 pasadas (0x00 / 0xFF / random) al borrar archivos.
# Solo util en HDD magnetico; en SSD/CoW no da garantias forenses.
# Por defecto usa os.unlink() directo para evitar escrituras innecesarias.
# OPENGRAB_SECURE_DELETE=0
