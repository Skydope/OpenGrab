# OpenGrab — Environment configuration
# Copy this file to .env and adjust as needed.
#
# Auth: if OPENGRAB_TOKEN is left empty (or unset), a random token is
# generated at startup and printed to the logs. To run with NO auth at all
# (local dev only), set OPENGRAB_NO_AUTH=1 explicitly.
#
# If you want to expose OpenGrab on your LAN or internet:
#   - Set OPENGRAB_HOST=0.0.0.0
#   - Set OPENGRAB_TOKEN to a strong random value (or use the auto-generated one)
#   - Or place OpenGrab behind an nginx reverse proxy with TLS

OPENGRAB_HOST=127.0.0.1
OPENGRAB_PORT=8800
OPENGRAB_DIR=./downloads
OPENGRAB_TOKEN=
# OPENGRAB_NO_AUTH=0
OPENGRAB_MAX_JOBS=2
OPENGRAB_MAX_SIZE_MB=0
OPENGRAB_AUTOUPDATE=1
